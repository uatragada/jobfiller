# JobFiller local configuration examples.
# Copy to .env only if your shell or process manager loads .env files.

# Local Ollama endpoint. Remote URLs are rejected unless explicitly allowed.
OLLAMA_URL=http://127.0.0.1:11434

# Optional Ollama model name. Leave blank to use deterministic fallback grading.
JOBFILLER_OLLAMA_MODEL=

# Startup port preferences.
JOBFILLER_BACKEND_PORT=8001
JOBFILLER_BACKEND_PORT_MAX=8005
JOBFILLER_FRONTEND_PORT=5173
JOBFILLER_FRONTEND_PORT_MAX=5193

# Windows PowerShell runner only: reuse an already-running healthy backend.
JOBFILLER_REUSE_BACKEND=false

# Optional local output overrides.
JOBFILLER_OUTPUT_DIR=
JOBFILLER_SETTINGS_PATH=

# Optional local API token override for advanced users.
JOBFILLER_LOCAL_TOKEN=

# Remote Ollama is intentionally off by default.
JOBFILLER_ALLOW_REMOTE_OLLAMA=false

# Optional command or wrapper script launched with outputs/codex_scan_prompt.txt.
JOBFILLER_CODEX_SCAN_COMMAND=
